# Keep the Docker build context small and free of host-only / secret files.
# The build context for apps/api/Dockerfile is the repo ROOT.

# Dependencies & build output (rebuilt inside the image)
**/node_modules
**/dist
**/build
**/.turbo
.turbo
*.tsbuildinfo

# Local SQLite databases and journals (never ship dev data into an image)
**/*.db
**/*.db-journal
**/*.db-wal
**/*.db-shm
apps/api/prisma/dev.db
apps/api/prisma/prisma

# Secrets & local env (image gets config via runtime env vars)
**/.env
**/.env.local
**/.env.*.local
.env
.env.local

# Frontend app — not part of the API image
apps/web

# VCS / editor / OS noise
.git
.github
.idea
.vscode
.husky
.impeccable
**/*.log
.DS_Store

# Test / CI artifacts
playwright-report
test-results
e2e-results
coverage
.playwright-mcp
screenshots
