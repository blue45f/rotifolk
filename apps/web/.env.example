# --- API ---
# VITE_API_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000

# --- Dev ---
# MSW(목 API) 사용 시 true. `pnpm dev:mock` 스크립트가 자동 설정.
# VITE_USE_MSW=false

# --- SurveyDesk (피드백 위젯) ---
# SurveyDesk 배포 주소. 설정 시에만 우하단 피드백 위젯이 렌더됨(미설정=위젯 비활성).
# 예) https://surveydesk-api.vercel.app
# VITE_SURVEYDESK_URL=

# --- DeskCloud 위젯 ----------------------------------------------------------
# 규칙: 각 *_URL 이 설정됐을 때만 위젯이 렌더됨(미설정 = 완전 비활성, 기존 앱 기능 보존).
# *_PK 는 브라우저 노출이 안전한 공개 키. 미설정 시 pk_demo 로 폴백.
# 아래 예) 값은 운영 배포 주소(라이브). 소스에는 하드코딩하지 않고 env 로만 주입한다.
#
# ChangelogDesk — 좌하단 "새 소식" 런처(인앱 체인지로그).
# 예) https://changelogdesk-api.vercel.app
# VITE_CHANGELOGDESK_URL=
# VITE_CHANGELOGDESK_PK=
# NotifyDesk — 우상단 알림 벨(로그인 사용자에게만 표시).
# 예) https://notifydesk-api.vercel.app
# VITE_NOTIFYDESK_URL=
# VITE_NOTIFYDESK_PK=
# SearchDesk — ⌘⇧K 검색 팔레트(앱 기본 ⌘K 와 충돌 방지용 별도 단축키).
# 예) https://searchdesk-api.vercel.app
# VITE_SEARCHDESK_URL=
# VITE_SEARCHDESK_PK=
# CommunityDesk — 좌하단 커뮤니티 게시판 패널(ReviewDesk 와 겹치지 않게 분리 배치).
# 예) https://communitydesk-api.vercel.app
# VITE_COMMUNITYDESK_URL=
# VITE_COMMUNITYDESK_PK=
# ChatDesk — 우하단 채팅 위젯(로그인 사용자에게만 표시).
# 예) https://chatdesk-api.vercel.app
# VITE_CHATDESK_URL=
# VITE_CHATDESK_PK=
# ReviewDesk — 우하단 이용 후기 월(testimonial).
# 예) https://reviewdesk-api.vercel.app
# VITE_REVIEWDESK_URL=
# VITE_REVIEWDESK_PK=
#
# 의도적으로 미연동(앱의 핵심·차별 기능과 중복되어 generic 위젯으로 대체하지 않음):
#   MediaDesk(미디어 갤러리/업로더) — 아바타·이미지 업로드는 프로필 핵심 플로우라 유지.
#     예) https://16.176.210.195.nip.io/media
#   RealtimeDesk(프레즌스/라이브) — 5분 라운드 라이브 회전이 이 앱의 정체성이라 대체 불가.
#     예) https://16.176.210.195.nip.io/realtime
#   ModerationDesk(신고/모더레이션) — 호스트·참가자 맥락의 차단/신고 안전 플로우는 도메인 전용.
#     예) https://16.176.210.195.nip.io/moderation
