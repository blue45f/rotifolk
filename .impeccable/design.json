      "html": "<article class=\"ds-card\"><strong>루즈 셀러</strong><p>한남동 · 최대 18명</p></article>",
      "css": ".ds-card{padding:24px;border-radius:24px;background:var(--color-surface,oklch(100% 0 80));border:1px solid color-mix(in oklab,oklch(15% 0.025 290) 10%,transparent);box-shadow:0 2px 6px color-mix(in oklab,oklch(25% 0.10 10) 10%,transparent);transition:transform .2s cubic-bezier(.22,1,.36,1),box-shadow .2s}.ds-card:hover{transform:translateY(-3px);box-shadow:0 10px 24px color-mix(in oklab,oklch(25% 0.10 10) 12%,transparent)}.ds-card strong{font-size:1.125rem;font-weight:700}.ds-card p{color:oklch(60% 0.012 290);font-size:.875rem;margin-top:4px}"
