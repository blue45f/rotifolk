{
  "name": "@rotifolk/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:mock": "VITE_USE_MSW=true vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
