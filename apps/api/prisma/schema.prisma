// Rotifolk Prisma schema — SQLite (dev) / PostgreSQL (prod)
// 운영 전환 시 provider만 "postgresql"로 변경하면 됨.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ======================== USER ========================
model User {
  id            String  @id @default(cuid())
  email         String  @unique
  passwordHash  String? // 소셜 로그인(Google 등)만으로 가입한 계정은 null
  provider      String  @default("password") // password | google | kakao
  googleSub     String? @unique // Google 계정 고유 ID(sub) — 소셜 로그인 식별자
  nickname      String
  role          String  @default("host") // 누구나 모임 개설 가능 — participant | host | admin
  bio           String?
  gender        String? // male | female | other | private
  birthYear     Int?
  interestsJson String  @default("[]")
  mbti          String?
  trustScore    Float   @default(50)
  hostedCount   Int     @default(0)
  joinedCount   Int     @default(0)
  isVerified    Boolean @default(false)
  homeArea      String?
  homeLat       Float?
  homeLng       Float?

  // 연락처 연결 — 매칭 성사 시 상호 동의한 채널만 단계적으로 공개 (부담 낮음→높음)
  phone          String?
  phoneHash      String? // 정규화 번호의 해시 — 지인 회피 대조용(원본 미저장)
  shareContact   Boolean @default(false) // 전화번호 공개 동의 (가장 긴밀)
  kakaoId        String? // 카카오톡 ID (공개 동의 시 상대에게)
  shareKakao     Boolean @default(false)
  instagram      String? // 인스타그램 핸들
  shareInstagram Boolean @default(false)
  avoidSameCompany Boolean @default(false) // 같은 회사 사람 자동 회피

  // 사전 프로필 — 이상형/대화 프롬프트/찾는 관계/한 줄 등 (아이스브레이커·매칭 활용)
  profileJson String @default("{}")

  // 신상 인증 (opt-in, 개인정보 최소화 — 연봉은 구간만, 정확액 미저장)
  occupation        String? // 직업 카테고리/직무
  company           String? // 회사명 (비공개 가능)
  incomeBand        String? // none | u3000 | b3000_5000 | b5000_7000 | b7000_10000 | o10000 (만원)
  maritalStatus     String? // single | married | divorced | widowed | private
  hasChildren       Boolean? // 아이 유무 (돌싱 모임 등 대상 필터용)
  education         String? // highschool | college | bachelor | master | doctorate | private
  verifiedFieldsJson String @default("[]") // 인증 완료 필드 ["identity","job","company","income","marital","education"]
  visibilityJson     String @default("{}") // 필드별 공개범위 { income: "matched", company: "hidden", ... }

  // 민감 정보 노출 설정
  showLikesReceived     Boolean @default(true) // 받은 호감 수를 남에게 공개
  joinPopularityRanking Boolean @default(true) // 오늘의 인기남/인기녀 선정 대상에 포함

  referralCode String @unique @default(cuid())
  pointsKRW    Int    @default(0)

  avatarId String? @unique
  avatar   Avatar? @relation(fields: [avatarId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hostedParties     Party[]           @relation("PartyHost")
  participations    Participation[]
  ordersPlaced      Order[]           @relation("OrderUser")
  quizAnswers       QuizAnswer[]
  midMatchVotes     MidMatchVote[]    @relation("MidVoteFrom")
  midMatchVotesIn   MidMatchVote[]    @relation("MidVoteTo")
  finalMatchVotes   FinalMatchVote[]  @relation("FinalVoteFrom")
  finalMatchVotesIn FinalMatchVote[]  @relation("FinalVoteTo")
  registeredVenues  Venue[]           @relation("VenueOwner")
  chatMemberships   ChatMembership[]
  chatMessages      ChatMessage[]
  blocksMade        UserBlock[]       @relation("BlockerRel")
  blocksAgainst     UserBlock[]       @relation("BlockedRel")
  reviewsWritten    Review[]          @relation("ReviewFrom")
  reviewsReceived   Review[]          @relation("ReviewTarget")
  reportsFiled      Report[]          @relation("ReportFrom")
  reportsAgainst    Report[]          @relation("ReportTarget")
  following         Follow[]          @relation("FollowerRel")
  followers         Follow[]          @relation("FollowingRel")
  savedParties      SavedParty[]      @relation("SavedByUser")
  partyPhotos       PartyPhoto[]      @relation("PhotosUploaded")
  photoLikes        PhotoLike[]       @relation("PhotoLikes")
  notifications     Notification[]    @relation("UserNotifications")
  hostApplications  HostApplication[] @relation("HostApplications")
  payments          Payment[]         @relation("UserPayments")
  referralsGiven    Referral[]        @relation("Referrer")
  referralReceived  Referral?         @relation("Referred")
  venueBookingsMade VenueBooking[]    @relation("VenueBookingRequester")
  notesSent         PartyNote[]       @relation("NoteFrom")
  notesReceived     PartyNote[]       @relation("NoteTo")
  avoidContacts     AvoidContact[]    @relation("AvoidOwner")
  communityPosts     CommunityPost[]   @relation("CommunityPostAuthor")
  communityComments  CommunityComment[] @relation("CommunityCommentAuthor")
  contactExchangeRequestsSent     ContactExchangeRequest[] @relation("ContactExchangeRequester")
  contactExchangeRequestsReceived ContactExchangeRequest[] @relation("ContactExchangeReceiver")
  contactExchangeRequestsDecided  ContactExchangeRequest[] @relation("ContactExchangeDecider")

  @@index([role])
  @@index([createdAt])
}

// ======================== AVATAR ========================
model Avatar {
  id         String @id @default(cuid())
  ownerId    String @unique
  mood       String // chill | sparkling | curious | witty | cozy | mystery
  hue        String // #RRGGBB
  pattern    String // solid | gradient | sparkle | wave | aurora | confetti
  emojiBadge String
  faceSeed   String

  // 아바타 빌더 고도화
  backdrop        String  @default("none") // none | halo | spotlight | bokeh | grid | wine-stain
  accessoriesJson String  @default("[]") // 모자/안경/이펙트 등
  vibeWord        String? // 한 단어 무드 (예: "차분", "장난꾸러기")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?
}

// ======================== VENUE ========================
model Venue {
  id              String  @id @default(cuid())
  name            String
  kind            String // wine-bar | cafe | tea-house | whisky-bar | ...
  area            String
  address         String
  lat             Float?
  lng             Float?
  capacity        Int
  pricePerHourKRW Int
  amenitiesJson   String  @default("[]")
  partnered       Boolean @default(false)
  description     String?
  photosJson      String  @default("[]")
  contactPhone    String?
  rating          Float   @default(0)
  reviewCount     Int     @default(0)

  // ── 섭외/예약 고도화 (offhours 참고) ──
  instantBook        Boolean @default(false) // true면 호스트 요청 즉시 확정
  cleaningFeeKRW     Int     @default(0)
  minHours           Int     @default(2) // 최소 대관 시간
  openMinute         Int     @default(660) // 영업 시작 (분, 0~1440) 기본 11:00
  closeMinute        Int     @default(1380) // 영업 종료 기본 23:00
  closedWeekdaysJson String  @default("[]") // 정기 휴무 요일 [0=일 ... 6=토]
  weekendMultiplier  Float   @default(1) // 주말 가격 배수
  peakMultiplier     Float   @default(1) // 피크 시간 가격 배수
  arrivalGuideJson   String  @default("{}") // 도착 가이드(주차/출입/와이파이 등)
  vibeTagsJson       String  @default("[]") // 무드 태그 ["조용한","루프뷰"]
  useCasesJson       String  @default("[]") // 추천 용도 ["와인모임","북토크"]
  hostBlurb          String? // 사장님 한마디 (직접 호스팅 소개)
  selfHostEnabled    Boolean @default(true) // 사장님이 직접 파티 개설 허용

  ownerId String?
  owner   User?   @relation("VenueOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  parties   Party[]
  menuItems MenuItem[]
  bookings  VenueBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, area])
  @@index([partnered])
}

model MenuItem {
  id             String  @id @default(cuid())
  venueId        String
  venue          Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  kind           String // drink | snack | dessert | glassware | custom
  name           String
  description    String?
  priceKRW       Int
  availability   String  @default("paid") // paid | included | unlimited | course
  coursePosition Int? // course일 때 진행 순서 (1부터)
  perPersonLimit Int? // 1인 한도 (없으면 null)
  imageUrl       String?
  isAvailable    Boolean @default(true)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId])
  @@index([venueId, availability])
}

// ======================== PARTY ========================
model Party {
  id              String   @id @default(cuid())
  title           String
  description     String
  hostId          String
  host            User     @relation("PartyHost", fields: [hostId], references: [id], onDelete: Cascade)
  venueId         String
  venue           Venue    @relation(fields: [venueId], references: [id])
  coverImageUrl   String?
  startAt         DateTime
  endAt           DateTime
  minParticipants Int
  maxParticipants Int
  status          String   @default("open") // draft|open|full|locked|live|ended|cancelled

  category              String // wine|coffee|tea|whisky|cocktail|beer|sake|natural-wine|dessert|custom
  rotationMode          String
  roundDurationSec      Int
  totalRounds           Int
  breakBetweenRoundsSec Int     @default(30)
  enableMidMatching     Boolean @default(true)
  enableFinalMatching   Boolean @default(true)
  enableQuiz            Boolean @default(true)
  enableQuestionCards   Boolean @default(true)
  enableLiveOrders      Boolean @default(true)
  enableAvatarOnly      Boolean @default(false)

  // ── 매칭 결과 정책 (차별화) ──
  matchScope             String  @default("mutual-only") // mutual-only | top-n | all-participants | mutual-plus-top-n
  contactExchangePolicy  String  @default("mutual-consent") // mutual-consent | chat-only | open-after-match
  maxMatchesPerPerson    Int     @default(3) // top-n일 때 1인당 최대 연결 수
  connectionMode         String  @default("chat") // (레거시) chat | phone | both
  connectionChannelsJson String  @default("[\"chat\"]") // 제공 연결 채널 ["chat","instagram","kakao","phone"]
  groupAfterParty        Boolean @default(false) // 종료 후 전원 그룹 채팅 개설
  revealPopular          Boolean @default(true) // 종료 후 오늘의 인기남/인기녀 공개

  // ── 쪽지 교환 (커피 모임 오프라인 의식) ──
  enableNotes  Boolean @default(true)
  noteDelivery String  @default("party-end") // instant | party-end
  noteQuota    Int     @default(5) // 1인당 보낼 수 있는 쪽지 상한 (신중한 선택 유도)

  // ── 라운드 대화 도우미 (게임/질문/운세/이상형) ──
  enableConversationKit Boolean @default(true)

  basePriceKRW        Int    @default(0)
  drinkPackage        String @default("per-glass") // none | per-glass | unlimited | paired
  snackPackage        String @default("none") // none | per-plate | course | pairing-bites
  refundDeadlineHours Int    @default(24)
  // 성별·연령별 참여 비용 규칙 (먼저 매칭되는 규칙 적용, 없으면 basePriceKRW)
  // [{ gender?: "male"|"female", ageMin?, ageMax?, priceKRW, label? }]
  pricingRulesJson String @default("[]")

  tagsJson    String  @default("[]")
  ageMin      Int?
  ageMax      Int?
  // 성별별 나이 제한 (없으면 ageMin/ageMax 공통값 적용)
  maleAgeMin   Int?
  maleAgeMax   Int?
  femaleAgeMin Int?
  femaleAgeMax Int?
  genderRatio  String?
  // 참가에 필요한 인증 (제출/검증 완료 필수) — ["identity","marital","company","job","education","income"]
  requiredVerificationsJson String @default("[]")
  // 대상 설정 — 허용 혼인상태(빈 배열=무관, 예 ["divorced"]=돌싱 전용), 아이 유무 정책
  maritalRequirementJson String @default("[]") // ["single","divorced","widowed",...]
  childrenPolicy         String @default("any") // any | has | none

  // ── 모임 포맷 & 로테이션 구조 ──
  format         String @default("rotation") // rotation | note-ting | mixer
  rotationFormat String @default("one-on-one") // one-on-one | many-to-one | many-to-many
  groupSize      Int    @default(2) // N:N 테이블 인원 / N:1 그룹 크기

  // ── 모집 규모 · 성비 · 자동 취소 ──
  genderRatioTarget String @default("any") // 목표 남:여 성비 "any" | "1:1" | "2:3" 등
  ratioTolerance    Int    @default(1) // 진행 중 허용 성비 편차 (인원 수 기준)
  maleCap           Int? // 남성 모집 상한 (null=성비×정원에서 자동 산출)
  femaleCap         Int? // 여성 모집 상한
  minMale           Int? // 성사 최소 남성 수 (보조 바닥값)
  minFemale         Int? // 성사 최소 여성 수 (보조 바닥값)
  autoCancelAt      DateTime? // 이 시각까지 성비/인원 미달 시 자동 취소
  autoCancelReason  String?

  currentRoundIndex Int @default(0)

  isInstant Boolean @default(false)
  quickCode String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participations  Participation[]
  rounds          Round[]
  quizQuestions   QuizQuestion[]
  questionCards   QuestionCard[]
  orders          Order[]
  events          LiveEvent[]
  finalMatchVotes FinalMatchVote[]
  midMatchVotes   MidMatchVote[]
  finalMatches    FinalMatch[]
  chatRooms       ChatRoom[]
  reviews         Review[]
  reports         Report[]
  savedBy         SavedParty[]
  photos          PartyPhoto[]
  payments        Payment[]
  notes           PartyNote[]
  venueBooking    VenueBooking?
  contactExchangeRequests ContactExchangeRequest[]
  communityPosts  CommunityPost[]

  @@index([status, startAt])
  @@index([category])
  @@index([hostId])
}

model Participation {
  id          String    @id @default(cuid())
  partyId     String
  party       Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("pending") // pending|confirmed|waitlist|checked-in|cancelled|no-show
  seatNumber  Int?
  checkedInAt DateTime?
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partyId, userId])
  @@index([userId])
  @@index([partyId, status])
}

// ======================== ROUND / PAIR ========================
model Round {
  id          String    @id @default(cuid())
  partyId     String
  party       Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  index       Int
  status      String    @default("queued") // queued|live|finished
  durationSec Int
  startedAt   DateTime?
  finishedAt  DateTime?

  pairs Pair[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partyId, index])
  @@index([partyId, status])
}

model Pair {
  id            String @id @default(cuid())
  roundId       String
  round         Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  seatLabel     String
  memberIdsJson String // JSON array of userIds

  questionCardDraws QuestionCardDraw[]

  createdAt DateTime @default(now())

  @@index([roundId])
}

// ======================== MATCH ========================
model MidMatchVote {
  id         String @id @default(cuid())
  partyId    String
  party      Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User   @relation("MidVoteFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User   @relation("MidVoteTo", fields: [toUserId], references: [id], onDelete: Cascade)
  roundIndex Int

  createdAt DateTime @default(now())

  @@unique([partyId, fromUserId, toUserId, roundIndex])
  @@index([partyId, toUserId])
}

model FinalMatchVote {
  id         String @id @default(cuid())
  partyId    String
  party      Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User   @relation("FinalVoteFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User   @relation("FinalVoteTo", fields: [toUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([partyId, fromUserId, toUserId])
  @@index([partyId, toUserId])
}

model FinalMatch {
  id        String   @id @default(cuid())
  partyId   String
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userAId   String
  userBId   String
  result    String // mutual|pending|declined
  matchedAt DateTime @default(now())

  @@unique([partyId, userAId, userBId])
  @@index([partyId])
}

model ContactExchangeRequest {
  id          String   @id @default(cuid())
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User     @relation("ContactExchangeRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ContactExchangeReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  decidedById String?
  decidedBy   User?    @relation("ContactExchangeDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  channel     String
  status      String   @default("pending") // pending | approved | rejected
  decidedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([partyId, requesterId, receiverId, channel])
  @@index([partyId, receiverId, status])
  @@index([partyId, requesterId, status])
  @@index([decidedById])
}

// ======================== QUIZ ========================
model QuizQuestion {
  id                 String    @id @default(cuid())
  partyId            String
  party              Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  kind               String // multiple-choice|true-false|open-text|image-pick
  prompt             String
  optionsJson        String    @default("[]")
  correctOptionIndex Int?
  durationSec        Int       @default(20)
  imageUrl           String?
  launchedAt         DateTime?

  answers QuizAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partyId])
}

model QuizAnswer {
  id                  String       @id @default(cuid())
  questionId          String
  question            QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId              String
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedOptionIndex Int?
  freeText            String?
  answeredAt          DateTime     @default(now())
  isCorrect           Boolean?
  responseMs          Int?

  @@unique([questionId, userId])
  @@index([userId])
}

// ======================== QUESTION CARD ========================
model QuestionCard {
  id        String  @id @default(cuid())
  partyId   String?
  party     Party?  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  depth     String // icebreaker|casual|deeper|spicy
  prompt    String
  category  String?
  language  String  @default("ko")
  usedCount Int     @default(0)

  draws QuestionCardDraw[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([depth])
  @@index([partyId])
}

model QuestionCardDraw {
  id      String       @id @default(cuid())
  cardId  String
  card    QuestionCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  pairId  String?
  pair    Pair?        @relation(fields: [pairId], references: [id], onDelete: SetNull)
  drawnAt DateTime     @default(now())

  @@index([cardId])
}

// ======================== ORDER ========================
model Order {
  id          String    @id @default(cuid())
  partyId     String
  party       Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("OrderUser", fields: [userId], references: [id], onDelete: Cascade)
  seatLabel   String?
  totalKRW    Int
  status      String    @default("requested") // requested|accepted|preparing|served|cancelled
  requestedAt DateTime  @default(now())
  servedAt    DateTime?
  note        String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partyId, status])
  @@index([userId])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
  name         String
  quantity     Int
  priceKRW     Int // 단가 (무제한·코스는 0)
  billable     Boolean  @default(true)
  availability String   @default("paid")
  note         String?

  @@index([orderId])
}

// ======================== SAVED PARTY (북마크) ========================
model SavedParty {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation("SavedByUser", fields: [userId], references: [id], onDelete: Cascade)
  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, partyId])
  @@index([userId])
  @@index([partyId])
}

// ======================== HOST APPLICATION ========================
model HostApplication {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation("HostApplications", fields: [userId], references: [id], onDelete: Cascade)
  introduction      String
  hostingStyle      String // "차분 / 따뜻 / 진지 / 발랄"
  plannedCategories String // JSON array
  experience        String?
  status            String   @default("pending") // pending | approved | rejected
  reviewedById      String?
  reviewedNote      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

// ======================== REVENUE RULE CONFIG ========================
model RevenueRuleConfig {
  key                    String   @id
  platformFeePercent     Float    @default(8)
  refundRetentionPercent Float    @default(0)
  minimumHostPayoutPercent Float   @default(85)
  updatedBy              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([updatedAt])
}

model RevenueRuleHistory {
  id                      String   @id @default(cuid())
  key                     String
  fromPlatformFeePercent   Float
  toPlatformFeePercent     Float
  fromRefundRetentionPercent Float
  toRefundRetentionPercent Float
  fromMinimumHostPayoutPercent Float
  toMinimumHostPayoutPercent Float
  changedBy               String?
  reason                  String?
  changedAt               DateTime @default(now())

  @@index([key, changedAt(sort: Desc)])
}

model MonitoringPolicyConfig {
  key                        String   @id
  warningRefundRatePercent    Float    @default(12)
  dangerRefundRatePercent     Float    @default(25)
  topPartyConcentrationPercent Float  @default(70)
  updatedBy                  String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([updatedAt])
}

model MonitoringPolicyHistory {
  id                               String   @id @default(cuid())
  key                              String
  fromWarningRefundRatePercent      Float
  toWarningRefundRatePercent        Float
  fromDangerRefundRatePercent       Float
  toDangerRefundRatePercent         Float
  fromTopPartyConcentrationPercent  Float
  toTopPartyConcentrationPercent    Float
  changedBy                        String?
  reason                           String?
  changedAt                        DateTime @default(now())

  @@index([key, changedAt(sort: Desc)])
}

// ======================== PAYMENT ========================
model Payment {
  id         String    @id @default(cuid())
  partyId    String
  party      Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  amountKRW  Int
  status     String    @default("paid") // pending | paid | refunded | cancelled
  method     String    @default("card") // card | kakao | toss | mock
  paidAt     DateTime?
  refundedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([partyId])
}

// ======================== NOTIFICATION ========================
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  kind      String // party_join | party_starting | match_made | host_review | message
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ======================== COMMUNITY ========================
model CommunityPost {
  id           String   @id @default(cuid())
  authorId     String
  author       User     @relation("CommunityPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  partyId      String?
  party        Party?   @relation(fields: [partyId], references: [id], onDelete: SetNull)
  title        String
  body         String
  category     String   @default("question") // question | after-party | venue-tip | match-review
  area         String?
  tagsJson     String   @default("[]")
  status       String   @default("open") // open | hidden | removed
  commentCount Int      @default(0)
  lastCommentAt DateTime?

  comments CommunityComment[]
  reports  Report[] @relation("CommunityPostReports")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, createdAt])
  @@index([area, createdAt])
  @@index([authorId, createdAt])
  @@index([partyId])
}

model CommunityComment {
  id        String @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User   @relation("CommunityCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    CommunityComment?  @relation("CommunityReplyThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   CommunityComment[] @relation("CommunityReplyThread")
  reports   Report[] @relation("CommunityCommentReports")
  body      String
  status    String @default("visible") // visible | hidden | removed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([parentId, createdAt])
  @@index([authorId, createdAt])
}

// ======================== PARTY PHOTO ========================
model PartyPhoto {
  id        String      @id @default(cuid())
  partyId   String
  party     Party       @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("PhotosUploaded", fields: [userId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  createdAt DateTime    @default(now())
  likes     PhotoLike[]

  @@index([partyId, createdAt])
}

model PhotoLike {
  id        String     @id @default(cuid())
  photoId   String
  photo     PartyPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation("PhotoLikes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([photoId, userId])
  @@index([photoId])
}

// ======================== REFERRAL ========================
model Referral {
  id         String   @id @default(cuid())
  referrerId String
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId String   @unique
  referred   User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  bonusKRW   Int      @default(3000)
  createdAt  DateTime @default(now())

  @@index([referrerId])
}

// ======================== FOLLOW ========================
model Follow {
  id          String @id @default(cuid())
  followerId  String
  follower    User   @relation("FollowerRel", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User   @relation("FollowingRel", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

// ======================== SAFETY / REVIEW ========================
model UserBlock {
  id        String  @id @default(cuid())
  blockerId String
  blocker   User    @relation("BlockerRel", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User    @relation("BlockedRel", fields: [blockedId], references: [id], onDelete: Cascade)
  reason    String?

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Review {
  id            String    @id @default(cuid())
  partyId       String?
  party         Party?    @relation(fields: [partyId], references: [id], onDelete: SetNull)
  fromUserId    String
  fromUser      User      @relation("ReviewFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  targetUserId  String?
  targetUser    User?     @relation("ReviewTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  rating        Int
  body          String
  anonymous     Boolean   @default(false)
  tagsJson      String    @default("[]")
  hostReply     String?
  hostRepliedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partyId])
  @@index([targetUserId])
}

model Report {
  id           String  @id @default(cuid())
  reporterId   String
  reporter     User    @relation("ReportFrom", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUserId String?
  targetUser   User?   @relation("ReportTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  partyId      String?
  party        Party?  @relation(fields: [partyId], references: [id], onDelete: SetNull)
  communityPostId String?
  communityPost   CommunityPost? @relation("CommunityPostReports", fields: [communityPostId], references: [id], onDelete: SetNull)
  communityCommentId String?
  communityComment   CommunityComment? @relation("CommunityCommentReports", fields: [communityCommentId], references: [id], onDelete: SetNull)
  reporterTargetKey String?
  kind         String
  body         String
  status       String  @default("open")
  resolvedById String?
  resolvedNote String?
  autoHiddenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([reporterId, reporterTargetKey, status])
  @@index([reporterTargetKey, status])
  @@index([communityPostId])
  @@index([communityCommentId])
}

model ReportAuditLog {
  id           String   @id @default(cuid())
  reportId     String?
  actorId      String?
  action       String
  note         String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())

  @@index([reportId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

// ======================== CHAT ========================
model ChatRoom {
  id            String    @id @default(cuid())
  kind          String // group | pair
  partyId       String?
  party         Party?    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  title         String?
  lastMessageAt DateTime?

  memberships ChatMembership[]
  messages    ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partyId, kind])
}

model ChatMembership {
  id         String    @id @default(cuid())
  roomId     String
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?

  createdAt DateTime @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id       String   @id @default(cuid())
  roomId   String
  room     ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body     String
  kind     String   @default("text") // text | system | split-bill
  metaJson String? // 엔빵 정산 등 메타데이터

  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

// ======================== LIVE EVENT ========================
model LiveEvent {
  id          String    @id @default(cuid())
  partyId     String
  party       Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  kind        String // cheers|reveal|mini-game|shuffle|photo-time|announcement|compliment-rain|gift-card
  payloadJson String    @default("{}")
  triggeredBy String
  triggeredAt DateTime  @default(now())
  expiresAt   DateTime?

  @@index([partyId, triggeredAt])
}

// ======================== VENUE BOOKING (섭외 요청) ========================
// 모임 호스트가 남의 공간을 빌릴 때의 예약 라이프사이클.
// 사장님이 자기 공간에서 직접 여는 경우엔 booking 없이 Party가 바로 생성된다.
model VenueBooking {
  id          String @id @default(cuid())
  venueId     String
  venue       Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  requesterId String // 공간을 빌리려는 모임 호스트
  requester   User   @relation("VenueBookingRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  ownerId     String? // 요청 시점의 공간 주인 스냅샷 (인박스 조회용)

  partyId String? @unique // 확정 후 연결된 파티
  party   Party?  @relation(fields: [partyId], references: [id], onDelete: SetNull)

  startAt     DateTime
  endAt       DateTime
  partySize   Int
  category    String // 개설 예정 파티 카테고리
  noteToOwner String?
  status      String   @default("requested") // requested | confirmed | declined | cancelled | completed

  // 가격 스냅샷 (요청 시점 견적)
  hours          Float
  baseKRW        Int
  multiplier     Float @default(1)
  discountKRW    Int   @default(0)
  cleaningFeeKRW Int   @default(0)
  totalKRW       Int

  ownerMessage String? // 사장님 확정/거절 메시지
  decidedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId, status])
  @@index([venueId, startAt])
  @@index([ownerId, status])
}

// ======================== PARTY NOTE (쪽지) ========================
// 라운드에서 만난 상대에게 남기는 쪽지. noteDelivery에 따라 즉시 또는 파티 종료 후 도착.
model PartyNote {
  id           String  @id @default(cuid())
  partyId      String
  party        Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  fromUserId   String
  fromUser     User    @relation("NoteFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId     String
  toUser       User    @relation("NoteTo", fields: [toUserId], references: [id], onDelete: Cascade)
  roundIndex   Int?
  body         String
  emoji        String? // 분위기 스티커
  shareContact Boolean @default(false) // 보낸 사람이 연락처 동봉

  deliveredAt DateTime? // null이면 아직 미도착(파티 종료 시 도착)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([partyId, toUserId])
  @@index([toUserId, deliveredAt])
}

// ======================== AVOID CONTACT (지인 회피) ========================
// 마주치고 싶지 않은 사람의 전화번호 해시. 원본 번호는 저장하지 않는다.
// 같은 모임에 해시가 일치하는 참가자가 있으면 사전 경고.
model AvoidContact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("AvoidOwner", fields: [userId], references: [id], onDelete: Cascade)
  phoneHash String // sha256(정규화 번호)
  label     String? // 사용자 메모 (선택)
  createdAt DateTime @default(now())

  @@unique([userId, phoneHash])
  @@index([phoneHash])
}
