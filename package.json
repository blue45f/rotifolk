{
  "name": "rotifolk",
  "version": "0.1.0",
  "private": true,
  "description": "Rotifolk — 로테이션 파티 매칭 플랫폼 (와인/커피/차 로테이션 모임)",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel --filter=./apps/* run dev",
    "dev:web": "pnpm --filter @rotifolk/web run dev",
    "dev:api": "pnpm --filter @rotifolk/api run dev",
    "dev:mock": "pnpm --filter @rotifolk/web run dev:mock",
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:api-contracts": "node --test scripts/audit-api-contracts.test.mjs",
    "test:frontend-a11y": "node --test scripts/audit-frontend-a11y.test.mjs",
    "audit:api-contracts": "node scripts/audit-api-contracts.mjs --strict-mock",
    "audit:frontend-a11y": "node scripts/audit-frontend-a11y.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,yml,yaml}\"",
    "ci": "pnpm run db:generate && pnpm run test:api-contracts && pnpm run test:frontend-a11y && pnpm run audit:api-contracts && pnpm run audit:frontend-a11y && pnpm run lint:ci && pnpm run typecheck && pnpm run test && pnpm run build",
    "verify": "pnpm run validate:architecture && pnpm run ci",
    "verify:push": "pnpm run verify",
    "sonar": "npx --yes sonar-scanner",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:ci": "pnpm run lint:strict",
    "sonar:ci": "npx --yes sonar-scanner -Dsonar.qualitygate.wait=true",
    "seed": "pnpm --filter @rotifolk/api run seed",
    "db:generate": "pnpm --filter @rotifolk/api run prisma:generate",
    "db:push": "pnpm --filter @rotifolk/api run prisma:push",
    "db:reset": "pnpm --filter @rotifolk/api run prisma:reset",
    "validate:architecture": "node scripts/validate-architecture.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
