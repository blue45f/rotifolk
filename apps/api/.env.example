# --- App ---
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Database (Prisma) ---
# 개발 기본값: SQLite. 운영은 Postgres 사용 권장.
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="postgresql://rotifolk:rotifolk@localhost:5432/rotifolk"

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-secret-please
JWT_EXPIRES_IN=7d

# --- Optional: OAuth (Kakao) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:3000/api/auth/kakao/callback

# --- Revenue policy (percent values, clamped 0-100) ---
# 호스트 정산률 하한값(%). 예: 85 -> 정산율이 이 값 미만이면 경고/위험 상태로 표시.
MIN_HOST_PAYOUT_PERCENT=85
# 주문당 플랫폼 수수료(%) 기본 8.
PLATFORM_FEE_PERCENT=8
# 환불 시 보유 비율(%) 기본 0.
REFUND_RETENTION_PERCENT=0

# --- Privacy ---
# 연락처(전화번호) 해싱에 섞는 pepper. 운영에서는 반드시 변경하고 고정 유지.
# (기본값 'rotifolk-pepper'는 개발 전용)
CONTACT_PEPPER=change-me-contact-pepper
