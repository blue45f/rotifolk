// Rotifolk Prisma schema — SQLite (dev) / PostgreSQL (prod)
// 운영 전환 시 provider만 "postgresql"로 변경하면 됨.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ======================== USER ========================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nickname     String
  role         String   @default("host") // 누구나 모임 개설 가능 — participant | host | admin
  bio          String?
  gender       String?  // male | female | other | private
  birthYear    Int?
  interestsJson String  @default("[]")
  mbti         String?
  trustScore   Float    @default(50)
  hostedCount  Int      @default(0)
  joinedCount  Int      @default(0)
  isVerified   Boolean  @default(false)
  homeArea     String?
  homeLat      Float?
  homeLng      Float?

  avatarId     String?  @unique
  avatar       Avatar?  @relation(fields: [avatarId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hostedParties     Party[]            @relation("PartyHost")
  participations    Participation[]
  ordersPlaced      Order[]            @relation("OrderUser")
  quizAnswers       QuizAnswer[]
  midMatchVotes     MidMatchVote[]     @relation("MidVoteFrom")
  midMatchVotesIn   MidMatchVote[]     @relation("MidVoteTo")
  finalMatchVotes   FinalMatchVote[]   @relation("FinalVoteFrom")
  finalMatchVotesIn FinalMatchVote[]   @relation("FinalVoteTo")
  registeredVenues  Venue[]            @relation("VenueOwner")
  chatMemberships   ChatMembership[]
  chatMessages      ChatMessage[]
  blocksMade        UserBlock[]        @relation("BlockerRel")
  blocksAgainst     UserBlock[]        @relation("BlockedRel")
  reviewsWritten    Review[]           @relation("ReviewFrom")
  reviewsReceived   Review[]           @relation("ReviewTarget")
  reportsFiled      Report[]           @relation("ReportFrom")
  reportsAgainst    Report[]           @relation("ReportTarget")

  @@index([role])
  @@index([createdAt])
}

// ======================== AVATAR ========================
model Avatar {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  mood        String   // chill | sparkling | curious | witty | cozy | mystery
  hue         String   // #RRGGBB
  pattern     String   // solid | gradient | sparkle | wave
  emojiBadge  String
  faceSeed    String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?
}

// ======================== VENUE ========================
model Venue {
  id              String   @id @default(cuid())
  name            String
  kind            String   // wine-bar | cafe | tea-house | whisky-bar | ...
  area            String
  address         String
  lat             Float?
  lng             Float?
  capacity        Int
  pricePerHourKRW Int
  amenitiesJson   String   @default("[]")
  partnered       Boolean  @default(false)
  description     String?
  photosJson      String   @default("[]")
  contactPhone    String?
  rating          Float    @default(0)
  reviewCount     Int      @default(0)

  ownerId         String?
  owner           User?    @relation("VenueOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  parties         Party[]
  menuItems       MenuItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([kind, area])
  @@index([partnered])
}

model MenuItem {
  id             String   @id @default(cuid())
  venueId        String
  venue          Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  kind           String   // drink | snack | dessert | glassware | custom
  name           String
  description    String?
  priceKRW       Int
  availability   String   @default("paid") // paid | included | unlimited | course
  coursePosition Int?     // course일 때 진행 순서 (1부터)
  perPersonLimit Int?     // 1인 한도 (없으면 null)
  imageUrl       String?
  isAvailable    Boolean  @default(true)

  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([venueId])
  @@index([venueId, availability])
}

// ======================== PARTY ========================
model Party {
  id                  String   @id @default(cuid())
  title               String
  description         String
  hostId              String
  host                User     @relation("PartyHost", fields: [hostId], references: [id], onDelete: Cascade)
  venueId             String
  venue               Venue    @relation(fields: [venueId], references: [id])
  coverImageUrl       String?
  startAt             DateTime
  endAt               DateTime
  minParticipants     Int
  maxParticipants     Int
  status              String   @default("open") // draft|open|full|locked|live|ended|cancelled

  category            String   // wine|coffee|tea|whisky|cocktail|beer|sake|natural-wine|dessert|custom
  rotationMode        String
  roundDurationSec    Int
  totalRounds         Int
  breakBetweenRoundsSec Int    @default(30)
  enableMidMatching   Boolean  @default(true)
  enableFinalMatching Boolean  @default(true)
  enableQuiz          Boolean  @default(true)
  enableQuestionCards Boolean  @default(true)
  enableLiveOrders    Boolean  @default(true)
  enableAvatarOnly    Boolean  @default(false)

  basePriceKRW        Int      @default(0)
  drinkPackage        String   @default("per-glass") // none | per-glass | unlimited | paired
  snackPackage        String   @default("none")      // none | per-plate | course | pairing-bites
  refundDeadlineHours Int      @default(24)

  tagsJson            String   @default("[]")
  ageMin              Int?
  ageMax              Int?
  genderRatio         String?

  currentRoundIndex   Int      @default(0)

  isInstant           Boolean  @default(false)
  quickCode           String?  @unique

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  participations      Participation[]
  rounds              Round[]
  quizQuestions       QuizQuestion[]
  questionCards       QuestionCard[]
  orders              Order[]
  events              LiveEvent[]
  finalMatchVotes     FinalMatchVote[]
  midMatchVotes       MidMatchVote[]
  finalMatches        FinalMatch[]
  chatRooms           ChatRoom[]
  reviews             Review[]
  reports             Report[]

  @@index([status, startAt])
  @@index([category])
  @@index([hostId])
}

model Participation {
  id          String   @id @default(cuid())
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // pending|confirmed|waitlist|checked-in|cancelled|no-show
  seatNumber  Int?
  checkedInAt DateTime?
  note        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([partyId, userId])
  @@index([userId])
  @@index([partyId, status])
}

// ======================== ROUND / PAIR ========================
model Round {
  id           String   @id @default(cuid())
  partyId      String
  party        Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  index        Int
  status       String   @default("queued") // queued|live|finished
  durationSec  Int
  startedAt    DateTime?
  finishedAt   DateTime?

  pairs        Pair[]

  createdAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([partyId, index])
  @@index([partyId, status])
}

model Pair {
  id          String   @id @default(cuid())
  roundId     String
  round       Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  seatLabel   String
  memberIdsJson String   // JSON array of userIds

  questionCardDraws QuestionCardDraw[]

  createdAt   DateTime @default(now())

  @@index([roundId])
}

// ======================== MATCH ========================
model MidMatchVote {
  id          String   @id @default(cuid())
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  fromUserId  String
  fromUser    User     @relation("MidVoteFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User     @relation("MidVoteTo", fields: [toUserId], references: [id], onDelete: Cascade)
  roundIndex  Int

  createdAt   DateTime @default(now())

  @@unique([partyId, fromUserId, toUserId, roundIndex])
  @@index([partyId, toUserId])
}

model FinalMatchVote {
  id          String   @id @default(cuid())
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  fromUserId  String
  fromUser    User     @relation("FinalVoteFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User     @relation("FinalVoteTo", fields: [toUserId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([partyId, fromUserId, toUserId])
  @@index([partyId, toUserId])
}

model FinalMatch {
  id          String   @id @default(cuid())
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userAId     String
  userBId     String
  result      String   // mutual|pending|declined
  matchedAt   DateTime @default(now())

  @@unique([partyId, userAId, userBId])
  @@index([partyId])
}

// ======================== QUIZ ========================
model QuizQuestion {
  id              String   @id @default(cuid())
  partyId         String
  party           Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  kind            String   // multiple-choice|true-false|open-text|image-pick
  prompt          String
  optionsJson     String   @default("[]")
  correctOptionIndex Int?
  durationSec     Int      @default(20)
  imageUrl        String?
  launchedAt      DateTime?

  answers         QuizAnswer[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([partyId])
}

model QuizAnswer {
  id            String   @id @default(cuid())
  questionId    String
  question      QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedOptionIndex Int?
  freeText      String?
  answeredAt    DateTime @default(now())
  isCorrect     Boolean?
  responseMs    Int?

  @@unique([questionId, userId])
  @@index([userId])
}

// ======================== QUESTION CARD ========================
model QuestionCard {
  id          String   @id @default(cuid())
  partyId     String?
  party       Party?   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  depth       String   // icebreaker|casual|deeper|spicy
  prompt      String
  category    String?
  language    String   @default("ko")
  usedCount   Int      @default(0)

  draws       QuestionCardDraw[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([depth])
  @@index([partyId])
}

model QuestionCardDraw {
  id          String   @id @default(cuid())
  cardId      String
  card        QuestionCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  pairId      String?
  pair        Pair?    @relation(fields: [pairId], references: [id], onDelete: SetNull)
  drawnAt     DateTime @default(now())

  @@index([cardId])
}

// ======================== ORDER ========================
model Order {
  id          String   @id @default(cuid())
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("OrderUser", fields: [userId], references: [id], onDelete: Cascade)
  seatLabel   String?
  totalKRW    Int
  status      String   @default("requested") // requested|accepted|preparing|served|cancelled
  requestedAt DateTime @default(now())
  servedAt    DateTime?
  note        String?

  items       OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([partyId, status])
  @@index([userId])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
  name         String
  quantity     Int
  priceKRW     Int          // 단가 (무제한·코스는 0)
  billable     Boolean  @default(true)
  availability String   @default("paid")
  note         String?

  @@index([orderId])
}

// ======================== SAFETY / REVIEW ========================
model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("BlockerRel", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("BlockedRel", fields: [blockedId], references: [id], onDelete: Cascade)
  reason    String?

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Review {
  id            String   @id @default(cuid())
  partyId       String?
  party         Party?   @relation(fields: [partyId], references: [id], onDelete: SetNull)
  fromUserId    String
  fromUser      User     @relation("ReviewFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  targetUserId  String?
  targetUser    User?    @relation("ReviewTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  rating        Int
  body          String
  anonymous     Boolean  @default(false)
  tagsJson      String   @default("[]")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([partyId])
  @@index([targetUserId])
}

model Report {
  id            String   @id @default(cuid())
  reporterId    String
  reporter      User     @relation("ReportFrom", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUserId  String?
  targetUser    User?    @relation("ReportTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  partyId       String?
  party         Party?   @relation(fields: [partyId], references: [id], onDelete: SetNull)
  kind          String
  body          String
  status        String   @default("open")
  resolvedById  String?
  resolvedNote  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
}

// ======================== CHAT ========================
model ChatRoom {
  id          String   @id @default(cuid())
  kind        String   // group | pair
  partyId     String?
  party       Party?   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  title       String?
  lastMessageAt DateTime?

  memberships ChatMembership[]
  messages    ChatMessage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([partyId, kind])
}

model ChatMembership {
  id        String   @id @default(cuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?

  createdAt DateTime @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  kind      String   @default("text") // text | system | split-bill
  metaJson  String?  // 엔빵 정산 등 메타데이터

  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

// ======================== LIVE EVENT ========================
model LiveEvent {
  id           String   @id @default(cuid())
  partyId      String
  party        Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  kind         String   // cheers|reveal|mini-game|shuffle|photo-time|announcement|compliment-rain|gift-card
  payloadJson  String   @default("{}")
  triggeredBy  String
  triggeredAt  DateTime @default(now())
  expiresAt    DateTime?

  @@index([partyId, triggeredAt])
}
