# --- API ---
# VITE_API_URL=http://localhost:3000
# VITE_SOCKET_URL=http://localhost:3000

# --- Dev ---
# MSW(목 API) 사용 시 true. `pnpm dev:mock` 스크립트가 자동 설정.
# VITE_USE_MSW=false

# --- DeskCloud 네이티브 연동 -------------------------------------------------
# 위젯 임베드가 아니라 공개 npm SDK `@heejun/deskcloud` 의 브라우저(pk_) 클라이언트로
# 데이터만 받아 앱의 자체 컴포넌트·디자인 토큰으로 렌더한다(네이티브 룩앤필).
# 규칙: 각 *_URL 이 설정됐을 때만 활성화됨(미설정 = 비활성, 앱의 1차 기능으로 폴백).
# *_PK 는 브라우저 노출이 안전한 공개 키이며 미설정 시 pk_demo 로 폴백한다.
# 절대 secret 키(sk_)를 여기에 넣지 않는다(서버 전용 @heejun/deskcloud/server).
# 아래 예) 값은 운영 배포 주소(라이브). 소스에는 하드코딩하지 않고 env 로만 주입한다.
#
# SurveyDesk — 피드백(우하단 런처 → Sheet 설문). createSurveyClient.
# 예) https://surveydesk-api.vercel.app
# VITE_SURVEYDESK_URL=
# VITE_SURVEYDESK_PK=
# ChangelogDesk — "새 소식"(헤더 런처 → Sheet 변경 이력). createChangelogClient.
# 예) https://changelogdesk-api.vercel.app
# VITE_CHANGELOGDESK_URL=
# VITE_CHANGELOGDESK_PK=
# ReviewDesk — 이용 후기(홈 섹션의 testimonial 그리드). createReviewClient.
# 예) https://reviewdesk-api.vercel.app
# VITE_REVIEWDESK_URL=
# VITE_REVIEWDESK_PK=
#
# 의도적으로 미연동(앱의 핵심·차별 기능과 중복 → generic Desk 로 대체하지 않음):
#   NotifyDesk(알림) — 앱 자체 실시간 알림(헤더 벨 + /notifications)이 핵심 기능.
#     예) https://notifydesk-api.vercel.app
#   SearchDesk(검색) — 앱 자체 커맨드 팔레트(⌘K)와 검색 페이지가 핵심 기능.
#     예) https://searchdesk-api.vercel.app
#   CommunityDesk(커뮤니티) — 앱 자체 /community 페이지가 핵심 기능.
#     예) https://communitydesk-api.vercel.app
#   ChatDesk(채팅) — 앱 자체 실시간 채팅(매칭 후 1:1)이 핵심·차별 기능.
#     예) https://16.176.210.195.nip.io/chat
#   MediaDesk(미디어 갤러리/업로더) — 아바타·이미지 업로드는 프로필 핵심 플로우라 유지.
#     예) https://16.176.210.195.nip.io/media
#   RealtimeDesk(프레즌스/라이브) — 5분 라운드 라이브 회전이 이 앱의 정체성이라 대체 불가.
#     예) https://16.176.210.195.nip.io/realtime
#   ModerationDesk(신고/모더레이션) — 호스트·참가자 맥락의 차단/신고 안전 플로우는 도메인 전용.
#     예) https://16.176.210.195.nip.io/moderation
