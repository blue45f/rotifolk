# --- App ---
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Database (Prisma) ---
# 개발 기본값: SQLite. 운영은 Postgres 사용 권장.
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="postgresql://rotifolk:rotifolk@localhost:5432/rotifolk"

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-secret-please
JWT_EXPIRES_IN=7d

# --- Optional: OAuth (Kakao) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:3000/api/auth/kakao/callback
