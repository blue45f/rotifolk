      "css": ".ds-btn-gold{height:44px;padding:0 18px;border:none;border-radius:999px;background:var(--color-accent,oklch(74% 0.125 80));color:var(--color-accent-fg,oklch(20% 0.03 60));font-weight:600;font-size:1rem;cursor:pointer;transition:filter .2s,transform .14s cubic-bezier(.34,1.45,.64,1)}.ds-btn-gold:hover{filter:brightness(1.04)}.ds-btn-gold:active{transform:scale(.98)}"
