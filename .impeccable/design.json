      "html": "<button class=\"ds-chip\" aria-pressed=\"true\">🍷 와인</button>",
      "css": ".ds-chip{padding:7px 14px;border-radius:999px;border:1px solid color-mix(in oklab,oklch(15% 0.025 290) 10%,transparent);background:var(--color-surface,oklch(100% 0 80));color:var(--color-text-muted,oklch(45% 0.02 290));font-size:.875rem;font-weight:600;cursor:pointer;transition:all .2s cubic-bezier(.22,1,.36,1)}.ds-chip[aria-pressed=\"true\"]{background:var(--color-primary,oklch(36% 0.13 10));color:oklch(97% 0.02 80);border-color:transparent}"
