      "css": ".ds-btn-primary{height:44px;padding:0 18px;border:none;border-radius:999px;background:var(--color-primary,oklch(36% 0.13 10));color:var(--color-primary-fg,oklch(98% 0.005 80));font-weight:600;font-size:1rem;cursor:pointer;box-shadow:0 10px 24px color-mix(in oklab,oklch(25% 0.10 10) 12%,transparent);transition:background .2s cubic-bezier(.22,1,.36,1),transform .14s cubic-bezier(.34,1.45,.64,1)}.ds-btn-primary:hover{background:var(--color-primary-hover,oklch(30% 0.115 10))}.ds-btn-primary:active{transform:scale(.98)}.ds-btn-primary:focus-visible{outline:2px solid oklch(63% 0.115 10);outline-offset:3px}"
