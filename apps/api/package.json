{
  "name": "@rotifolk/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --watch --require ts-node/register --require tsconfig-paths/register src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "TS_NODE_PROJECT=./tsconfig.runtime.json node -r tsconfig-paths/register dist/apps/api/src/main.js",
    "start:migrate": "prisma db push --skip-generate --accept-data-loss && pnpm run start",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint via root'",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:reset": "prisma migrate reset --force",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@heejun/auth": "^0.3.1",
    "@heejun/contracts": "^0.1.0",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.26",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@rotifolk/shared": "workspace:*",
    "argon2": "^0.44.0",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.2.0",
    "nanoid": "^5.1.15",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.24",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
